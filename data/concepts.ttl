@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix : <http://example.org/>.

:fietsvoorbeeld a skos:ConceptScheme;
  rdfs:label "fiets voorbeeld";
.

:fiets a skos:Concept;
  skos:prefLabel "Fiets";
  skos:definition "Een fiets is een voertuig met twee [wielen], aangedreven door menskracht";
  skos:inScheme :fietsvoorbeeld;
  skos:broader :voertuig;
  skos:related :wiel;
.
:voertuig a skos:Concept;
  skos:prefLabel "Voertuig";
  skos:definition "Een voertuig is een beweegbaar goed, bedoeld om mensen en/of goederen mee te vervoeren";
  skos:inScheme :fietsvoorbeeld;
.
:wiel a skos:Concept;
  skos:prefLabel "Wiel";
  skos:definition "Een wiel is een ronddraaiend goed";
  skos:inScheme :fietsvoorbeeld;
  skos:hiddenLabel "Wielen";
.
